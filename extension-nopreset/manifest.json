{
  "manifest_version": 3,
  "name": "Razor ERP Auto-Fill (Lite)",
  "version": "1.1",
  "description": "Scrape a Razor ERP page and create/join a lot in LotSync (Convex)",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://secureitad.razorerp.com/*",
    "https://*.convex.cloud/*",
    "https://*.convex.site/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
